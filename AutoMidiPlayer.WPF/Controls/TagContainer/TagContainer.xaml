<UserControl x:Class="AutoMidiPlayer.WPF.Controls.TagContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:stylet="https://github.com/canton7/Stylet"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="400"
             x:Name="Root">
    <WrapPanel VerticalAlignment="Top">
        <ItemsControl ItemsSource="{Binding VisibleTags, ElementName=Root}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Padding="9,2" CornerRadius="9" Margin="0,0,6,6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                        <TextBlock Text="{Binding}" FontSize="10.5" Opacity="0.7"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Padding="9,2" CornerRadius="9" Margin="0,0,6,6"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Visibility="{Binding HasOverflow, ElementName=Root, Converter={x:Static stylet:BoolToVisibilityConverter.Instance}}">
            <TextBlock Text="{Binding OverflowCount, ElementName=Root, StringFormat=+{0}}" FontSize="10.5" Opacity="0.7"/>
            <Border.ToolTip>
                <ToolTip>
                    <ItemsControl ItemsSource="{Binding OverflowTags, ElementName=Root}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel MaxWidth="200" Margin="0,0,-6,-6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="9,2" CornerRadius="9" Margin="0,0,6,6"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <TextBlock Text="{Binding}" FontSize="10.5" Opacity="0.7"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ToolTip>
            </Border.ToolTip>
        </Border>
    </WrapPanel>
</UserControl>
