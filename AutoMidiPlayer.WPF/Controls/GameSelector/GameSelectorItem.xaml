<UserControl x:Class="AutoMidiPlayer.WPF.Controls.GameSelector.GameSelectorItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AutoMidiPlayer.WPF.Controls.GameSelector"
             xmlns:converters="clr-namespace:AutoMidiPlayer.WPF.Converters"
             xmlns:games="clr-namespace:AutoMidiPlayer.WPF.Core.Games"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="240">
    <UserControl.Resources>
        <converters:GameImageStateConverter x:Key="GameImageStateConverter"/>
    </UserControl.Resources>
    <UserControl.Template>
        <ControlTemplate TargetType="local:GameSelectorItem">
            <ControlTemplate.Resources>
                <Storyboard x:Key="SpinningBorderAnimation" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="AnimatedGradientRotation" 
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360" Duration="0:0:3" />
                </Storyboard>
            </ControlTemplate.Resources>
            <!-- The root border gives the background and stroke -->
    <Border x:Name="RootBorder"
            Cursor="Hand"
            CornerRadius="10"
            Padding="10"
            Margin="0,2"
            ClipToBounds="True"
            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
            BorderThickness="1"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
        
        <Grid>
            <!-- Animated Border for selection state -->
            <!-- We use an outer border that becomes visible when selected, having a rotating gradient brush -->
            <Border x:Name="SelectionBorder"
                    CornerRadius="10"
                    BorderThickness="2"
                    Opacity="0"
                    Margin="-10"
                    Padding="10">
                <Border.BorderBrush>
                    <LinearGradientBrush x:Name="AnimatedGradient" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource SystemAccentColorPrimary}" Offset="0.0"/>
                        <GradientStop Color="Transparent" Offset="0.5"/>
                        <GradientStop Color="{DynamicResource SystemAccentColorPrimary}" Offset="1.0"/>
                        <!-- The transform will be animated -->
                        <LinearGradientBrush.RelativeTransform>
                            <RotateTransform x:Name="AnimatedGradientRotation" CenterX="0.5" CenterY="0.5" Angle="0" />
                        </LinearGradientBrush.RelativeTransform>
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>
            
            <Border x:Name="HoverOverlay"
                    CornerRadius="10"
                    Margin="-10"
                    Background="{DynamicResource TextFillColorPrimaryBrush}"
                    Opacity="0"
                    IsHitTestVisible="False" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Width="44"
                        Height="44"
                        CornerRadius="10"
                        SnapsToDevicePixels="False"
                        UseLayoutRounding="True"
                        x:Name="ImageHost"
                        RenderOptions.BitmapScalingMode="Fant">
                    <Border.Background>
                        <ImageBrush Stretch="UniformToFill"
                                    RenderOptions.BitmapScalingMode="Fant">
                            <ImageBrush.ImageSource>
                                <MultiBinding Converter="{StaticResource GameImageStateConverter}">
                                    <Binding Path="ImagePath"/>
                                    <Binding Path="IsRunning"/>
                                </MultiBinding>
                            </ImageBrush.ImageSource>
                            <ImageBrush.RelativeTransform>
                                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                            </ImageBrush.RelativeTransform>
                        </ImageBrush>
                    </Border.Background>
                </Border>
                
                <StackPanel Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText"
                               Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    
                    <TextBlock x:Name="StatusText"
                               Text="{Binding StatusText}"
                               FontSize="11"
                               Opacity="0.6"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
            <ControlTemplate.Triggers>
                <!-- Hover Animations: Image Shrink/Grow -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0.04" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ImageScale" Storyboard.TargetProperty="ScaleX" To="1.08" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ImageScale" Storyboard.TargetProperty="ScaleY" To="1.08" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ImageScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ImageScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>

                <!-- Selection State -->
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="RootBorder" Property="BorderBrush" Value="Transparent" />
                    <Setter TargetName="SelectionBorder" Property="Opacity" Value="1" />
                    <Setter TargetName="TitleText" Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Name="SpinAction" Storyboard="{StaticResource SpinningBorderAnimation}" />
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="SpinAction" />
                    </DataTrigger.ExitActions>
                </DataTrigger>
                
                <!-- Running State for Status Text -->
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter TargetName="StatusText" Property="Foreground" Value="#4CAF50" />
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Template>
</UserControl>
