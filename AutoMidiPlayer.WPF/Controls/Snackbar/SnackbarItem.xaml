<UserControl x:Class="AutoMidiPlayer.WPF.Controls.Snackbar.SnackbarItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
             xmlns:snackbar="clr-namespace:AutoMidiPlayer.WPF.Controls.Snackbar"
             x:Name="Root"
             MaxWidth="{Binding ActualWidth,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={snackbar:PercentageConverter},
                        ConverterParameter=0.4}">

    <UserControl.RenderTransformOrigin>
        <Point X="0.5" Y="1.0" />
    </UserControl.RenderTransformOrigin>
    <UserControl.RenderTransform>
        <TransformGroup>
            <ScaleTransform x:Name="EntranceScale" />
            <ScaleTransform x:Name="RootScale" />
            <TranslateTransform x:Name="RootTranslate" />
        </TransformGroup>
    </UserControl.RenderTransform>

    <UserControl.Resources>
        <!-- Close button style: ghost, small, subtle -->
        <Style x:Key="SnackbarCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource ControlFillColorTertiaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Card border -->
    <Border x:Name="CardBorder"
            CornerRadius="6"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8"
                              ShadowDepth="2"
                              Opacity="0.18"
                              Direction="270"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Main content row -->
            <Grid Grid.Row="0" Margin="12,10,6,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Icon with accent ring -->
                <Grid Grid.Column="0"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      Width="28" Height="28">
                    <Ellipse Stroke="{Binding ResolvedIconRingBrush}"
                             StrokeThickness="2"
                             Fill="Transparent"/>
                    <ui:SymbolIcon Symbol="{Binding ResolvedIcon}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding ResolvedIconRingBrush}"
                                   Visibility="{Binding SymbolIconVisibility}"/>
                    <Image Source="{Binding IconSource}"
                           Width="16" Height="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding ImageIconVisibility}"/>
                </Grid>

                <!-- Text content -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <TextBlock Text="{Binding PrimaryText}"
                               FontSize="13"
                               FontWeight="Normal"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="None"/>
                    <TextBlock Text="{Binding SecondaryText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="None"
                               Margin="0,3,0,0"
                               Visibility="{Binding SecondaryTextVisibility}"/>
                    <!-- Action buttons -->
                    <ItemsControl ItemsSource="{Binding ActionButtons}"
                                  Margin="0,6,0,0"
                                  Visibility="{Binding ActionButtonsVisibility}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:Button Content="{Binding Text}"
                                                  Variant="{Binding Variant}"
                                                  ColorMode="{Binding ColorMode}"
                                                  Command="{Binding Command}"
                                                  CommandParameter="{Binding CommandParameter}"
                                                  Padding="8,4"
                                                  Margin="0,0,6,0"
                                                  FontSize="12"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Close button -->
                <Button Grid.Column="2"
                        VerticalAlignment="Top"
                        Margin="0,-2,-2,0"
                        Style="{StaticResource SnackbarCloseButtonStyle}"
                        Visibility="{Binding CloseButtonVisibility}"
                        Click="OnCloseButtonClick">
                    <ui:SymbolIcon Symbol="Dismiss16"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </Button>
            </Grid>

            <!-- Progress bar at very bottom -->
            <Border Grid.Row="1"
                    Height="3"
                    Margin="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Visibility="{Binding ProgressBarVisibility}">
                <Border.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black"
                                    SnapsToDevicePixels="True"
                                    CornerRadius="0,0,6,6"
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>

                <Border Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                        CornerRadius="0"
                        HorizontalAlignment="Left"
                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}">
                    <Border.RenderTransformOrigin>0,0.5</Border.RenderTransformOrigin>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressBarScaleTransform" ScaleX="1"/>
                    </Border.RenderTransform>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>
