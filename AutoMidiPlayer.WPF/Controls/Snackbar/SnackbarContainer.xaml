<UserControl x:Class="AutoMidiPlayer.WPF.Controls.Snackbar.SnackbarContainer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:AutoMidiPlayer.WPF.Helpers"
             xmlns:snackbar="clr-namespace:AutoMidiPlayer.WPF.Controls.Snackbar"
             x:Name="Root">

    <!-- The container is transparent and overlays the content area.
         Only the snackbar items and badge are hit-testable. -->

    <Grid>


        <!-- Scrollable area for snackbar items -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      helpers:ScrollEdgeFadeBehavior.IsEnabled="True"
                      helpers:ScrollEdgeFadeBehavior.FadeRampDistance="40"
                      helpers:ScrollEdgeFadeBehavior.EdgeFadeThickness="0.18"
                      helpers:ScrollEdgeFadeBehavior.MaxFadeOpacity="0.85"
                      IsHitTestVisible="True"
                      MaxHeight="{Binding ActualHeight,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={snackbar:PercentageConverter},
                                  ConverterParameter=0.75}">
            <Grid x:Name="ItemsHost"
                  Background="Transparent"
                  HorizontalAlignment="{Binding HorizontalAlignment, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  VerticalAlignment="Bottom"
                  IsHitTestVisible="True">
                
                <!-- The badge has been moved outside the ScrollViewer to prevent clipping -->
            </Grid>
        </ScrollViewer>

        <!-- Badge (positioned dynamically in code-behind) -->
        <Border x:Name="BadgeBorder"
                Panel.ZIndex="1000"
                CornerRadius="9"
                MinWidth="18" Height="18"
                Padding="4,0"
                IsHitTestVisible="False"
                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                Visibility="{Binding BadgeVisibility}">
            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
            <Border.RenderTransform>
                <ScaleTransform x:Name="BadgeScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>
            <TextBlock Text="{Binding Count}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
