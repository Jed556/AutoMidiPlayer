<UserControl x:Class="AutoMidiPlayer.WPF.Controls.SelectorPopupButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Focusable="False">
    <StackPanel ToolTip="{Binding ToolTip, ElementName=Root}">
        <Button x:Name="SelectorButton"
                Margin="0,1,0,0"
                Padding="7,3"
                HorizontalAlignment="Center"
                Click="SelectorButton_Click">
            <Button.Style>
                <Style TargetType="Button"
                       BasedOn="{StaticResource GhostIconButton}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsActive, ElementName=Root}"
                                     Value="True">
                            <Setter Property="Opacity"
                                    Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <ContentPresenter Content="{Binding ButtonContent, ElementName=Root}"/>
        </Button>

        <Popup x:Name="SelectorPopup"
               PlacementTarget="{Binding ElementName=SelectorButton}"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Margin="0,0,0,8"
                    CornerRadius="12"
                    Background="{DynamicResource ApplicationBackgroundBrush}">
                <Border Padding="8"
                        MaxWidth="{Binding PopupMaxWidth, ElementName=Root}"
                        HorizontalAlignment="Left"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <ListBox x:Name="SelectorListBox"
                             Padding="0"
                             Grid.IsSharedSizeScope="True"
                             BorderThickness="0"
                             Background="Transparent"
                             MaxHeight="{Binding PopupMaxHeight, ElementName=Root}"
                             ScrollViewer.VerticalScrollBarVisibility="Visible"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="True"
                             ItemsSource="{Binding ItemsSource, ElementName=Root}"
                             SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             SelectionChanged="SelectorListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="OverridesDefaultStyle"
                                        Value="True"/>
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch"/>
                                <Setter Property="Padding"
                                        Value="0"/>
                                <Setter Property="Margin"
                                        Value="0,1,10,1"/>
                                <Setter Property="Background"
                                        Value="Transparent"/>
                                <Setter Property="BorderBrush"
                                        Value="Transparent"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                                <Setter Property="FocusVisualStyle"
                                        Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              Margin="{TemplateBinding Margin}"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ItemBorder"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        BorderThickness="1"
                                        BorderBrush="Transparent"
                                        Background="Transparent">
                                    <ContentPresenter Content="{Binding}"
                                                      ContentTemplate="{Binding ItemTemplate, ElementName=Root}"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                                                 Value="True">
                                        <Setter TargetName="ItemBorder"
                                                Property="Background"
                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                 Value="True">
                                        <Setter TargetName="ItemBorder"
                                                Property="BorderBrush"
                                                Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                        <Setter TargetName="ItemBorder"
                                                Property="Background"
                                                Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Border>
        </Popup>
    </StackPanel>
</UserControl>
