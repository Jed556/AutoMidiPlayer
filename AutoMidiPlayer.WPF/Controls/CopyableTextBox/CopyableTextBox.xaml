<UserControl x:Class="AutoMidiPlayer.WPF.Controls.CopyableTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <Style x:Key="PassiveSelectableTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="TextBoxBase.IsReadOnlyCaretVisible"
                    Value="False"/>
            <Setter Property="CaretBrush"
                    Value="Transparent"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="FocusVisualStyle"
                    Value="{x:Null}"/>
            <Setter Property="IsTabStop"
                    Value="False"/>
            <Setter Property="SpellCheck.IsEnabled"
                    Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="0"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </UserControl.Resources>

    <Grid x:Name="RootGrid"
          ClipToBounds="True"
          MouseEnter="OnRootGridMouseEnter"
          MouseLeave="OnRootGridMouseLeave">
        <TextBox x:Name="MainTextBox"
                 Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource PassiveSelectableTextBoxStyle}"
                 HorizontalAlignment="Stretch"
                 IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
                 TextWrapping="{Binding TextWrapping, ElementName=Root}"
                 VerticalScrollBarVisibility="{Binding VerticalScrollBarVisibility, ElementName=Root}"
                 ScrollViewer.VerticalScrollBarVisibility="{Binding VerticalScrollBarVisibility, ElementName=Root}"
                 HorizontalScrollBarVisibility="{Binding HorizontalScrollBarVisibility, ElementName=Root}"
                 ScrollViewer.HorizontalScrollBarVisibility="{Binding HorizontalScrollBarVisibility, ElementName=Root}"
                 MaxHeight="{Binding TextBoxMaxHeight, ElementName=Root}"
                 AcceptsReturn="True"
                 AcceptsTab="False"
                 FontSize="{Binding FontSize, ElementName=Root}"
                 Background="Transparent"
                 BorderThickness="1"
                 Padding="8,6,8,6"/>

        <controls:Button x:Name="CopyButton"
                         ToolTip="{Binding CopyToolTip, ElementName=Root}"
                         Variant="Filled"
                         Icon="Copy16"
                         Opacity="0"
                         Width="32"
                         Height="32"
                         Padding="8"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,4,4,0"
                         Click="OnCopyClick"
                         MouseEnter="OnCopyButtonMouseEnter"
                         MouseLeave="OnCopyButtonMouseLeave"/>
    </Grid>
</UserControl>
