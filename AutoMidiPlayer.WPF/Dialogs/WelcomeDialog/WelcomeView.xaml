<UserControl x:Class="AutoMidiPlayer.WPF.Dialogs.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="450">

    <StackPanel Margin="0,16,0,0" MaxWidth="400">
        <StackPanel HorizontalAlignment="Center"
                    Margin="0,0,0,24">
            <Image Width="64"
                   Height="64"
                   Source="pack://application:,,,/Resources/logo.png"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

            <TextBlock Text="Welcome to Auto MIDI Player"
                       FontWeight="Bold"
                       FontSize="24"
                       TextAlignment="Center"/>

            <TextBlock Text="{Binding AppVersion, RelativeSource={RelativeSource AncestorType=ui:ContentDialog}}"
                       FontSize="12"
                       Opacity="0.6"
                       TextAlignment="Center"
                       Margin="0,4,0,0"/>

            <TextBlock Text="A feature-rich MIDI-to-key player for in-game instruments, built with C# and WPF and styled with Windows Mica."
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="12"
                       Opacity="0.8"
                       Margin="0,16,0,0"/>
        </StackPanel>

        <TextBlock Text="To help improve the app and fix crashes, we can collect basic system specifications and attach local log files when errors occur. No personal data is collected, and this is strictly for debugging." 
                   TextWrapping="Wrap" 
                   Margin="0,0,0,12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

        <ui:ToggleSwitch x:Name="TelemetryToggle"
                         Content="Opt-in to Crash Reporting &amp; Analytics" 
                         FontSize="12"
                         Margin="0,0,0,12"/>

        <TextBlock Text="You can change this preference later in Settings." 
                   TextWrapping="Wrap" 
                   FontSize="12"
                   Margin="0,0,0,24"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>

        <WrapPanel HorizontalAlignment="Center">
            <ui:Button Appearance="Secondary"
                       Padding="8,6,12,6"
                       Margin="0,0,8,0"
                       HorizontalContentAlignment="Left"
                       Click="OnWikiClicked">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Lightbulb28" Margin="0,0,8,0" FontSize="16" />
                    <TextBlock Text="Read the Wiki" VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
            <ui:Button Appearance="Secondary"
                       Padding="8,6,12,6"
                       HorizontalContentAlignment="Left"
                       Click="OnLicenseClicked">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Handshake16" Margin="0,0,8,0" FontSize="16" />
                    <TextBlock Text="License" VerticalAlignment="Center" />
                </StackPanel>
            </ui:Button>
        </WrapPanel>


    </StackPanel>
</UserControl>
