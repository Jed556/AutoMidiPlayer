<UserControl x:Class="AutoMidiPlayer.WPF.Dialogs.UnableToDeleteFileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <StackPanel Background="Transparent"
                Margin="0,0,12,0">
        <TextBlock Text="The file could not be deleted. It may be in use, read-only, or protected by permissions."
                   MaxWidth="640"
                   TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
