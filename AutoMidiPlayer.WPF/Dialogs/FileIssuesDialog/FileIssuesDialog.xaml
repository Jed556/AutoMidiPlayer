<ui:ContentDialog x:Class="AutoMidiPlayer.WPF.Dialogs.FileIssuesDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  Title="File Issues"
                  CloseButtonText="Close"
                  DefaultButton="Close">

    <ui:ContentDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </ui:ContentDialog.Resources>

    <StackPanel MinWidth="460"
                Background="Transparent"
                Margin="0,0,12,0"
                TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <TextBlock Text="File errors were found:"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"/>

        <StackPanel Visibility="{Binding HasMissingSongs, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Missing files"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <ScrollViewer MaxHeight="200"
                          BorderThickness="1"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <ItemsControl ItemsSource="{Binding MissingSongs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8,10,8"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding Title, FallbackValue=Unknown}"/>

                                    <ui:Button Grid.Column="1"
                                               Margin="8,0,0,0"
                                               Padding="6,2,6,2"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               ToolTip="Remove from database"
                                               Style="{DynamicResource GhostIconButton}"
                                               Content="✕"
                                               Click="OnRemoveMissingSongClick"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Margin="0,14,0,0"
                    Visibility="{Binding HasBadMidiFiles, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Bad MIDI files"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <ScrollViewer MaxHeight="220"
                          BorderThickness="1"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <ItemsControl ItemsSource="{Binding BadMidiFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8,10,8"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Orientation="Vertical">
                                        <TextBlock Text="{Binding Title, FallbackValue=Unknown}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Path, FallbackValue=''}"
                                                   Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Opacity="0.72"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                               Margin="8,0,0,0"
                                               Padding="6,2,6,2"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               ToolTip="Remove from database"
                                               Style="{DynamicResource GhostIconButton}"
                                               Content="✕"
                                               Click="OnRemoveBadMidiSongClick"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Margin="0,14,0,0"
                    Visibility="{Binding HasDuplicateConflicts, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Duplicate files"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Choose exactly one version per duplicate group. These selections stay available when reopening this conflicts menu."
                       Margin="0,0,0,8"
                       Opacity="0.72"
                       TextWrapping="Wrap"/>

            <ScrollViewer MaxHeight="220"
                          BorderThickness="1"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8,10,8"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding ExistingFileName}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding ExistingPath}"
                                               Margin="0,0,0,4"
                                               FontSize="11"
                                               Opacity="0.72"
                                               TextTrimming="CharacterEllipsis"/>

                                    <CheckBox Content="Current in library"
                                              Margin="0,4,0,0"
                                              IsChecked="{Binding UseCurrentVersion}"
                                              Click="OnUseCurrentVersionClick"/>

                                    <ItemsControl ItemsSource="{Binding DuplicateOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,4,0,0"
                                                            Orientation="Vertical">
                                                    <CheckBox Content="{Binding DuplicateFileName}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Click="OnUseDuplicateVersionClick"/>

                                                    <TextBlock Text="{Binding DuplicatePath}"
                                                               Margin="24,0,0,0"
                                                               FontSize="11"
                                                               Opacity="0.72"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <StackPanel Margin="0,14,0,0"
                    Visibility="{Binding HasRemovedExistingMidiFiles, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Removed but still in MIDI folder"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <ScrollViewer MaxHeight="200"
                          BorderThickness="1"
                          Padding="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <ItemsControl ItemsSource="{Binding RemovedExistingMidiFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8,10,8"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Orientation="Vertical">
                                        <TextBlock Text="{Binding Title, FallbackValue=Unknown}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Path, FallbackValue=''}"
                                                   Margin="0,2,0,0"
                                                   FontSize="11"
                                                   Opacity="0.72"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <ui:Button Padding="4"
                                                   ToolTip="Restore this MIDI file to the song list"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Style="{DynamicResource GhostIconButton}"
                                                   Click="OnRestoreRemovedExistingClick">
                                            <ui:SymbolIcon Symbol="ArrowClockwise24"/>
                                        </ui:Button>

                                        <ui:Button Margin="6,0,0,0"
                                                   Padding="4"
                                                   ToolTip="Delete this MIDI file from disk"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Style="{DynamicResource GhostIconButton}"
                                                   Click="OnDeleteRemovedExistingClick">
                                            <ui:SymbolIcon Symbol="Delete24"/>
                                        </ui:Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </StackPanel>
</ui:ContentDialog>
