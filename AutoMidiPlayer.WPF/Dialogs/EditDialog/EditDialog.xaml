<ui:ContentDialog x:Class="AutoMidiPlayer.WPF.Dialogs.EditDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
             xmlns:button="clr-namespace:AutoMidiPlayer.WPF.Controls.SelectorPopupButton.Button"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:helpers="clr-namespace:AutoMidiPlayer.WPF.Helpers"
                  PrimaryButtonText="Save"
                  SecondaryButtonText="Reset Defaults"
                  CloseButtonText="Cancel"
                  PrimaryButtonAppearance="Primary"
                  SecondaryButtonAppearance="Danger"
                  CloseButtonAppearance="Secondary"
                  DefaultButton="Primary"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  helpers:ScrollEdgeFadeBehavior.IsEnabled="True">

    <ui:ContentDialog.Resources>
        <DataTemplate x:Key="OffsetNoteTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock MinWidth="24"
                           HorizontalAlignment="Right"
                           FontSize="12"
                           Text="{Binding OffsetDisplay}"
                           TextAlignment="Right"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <TextBlock Margin="6,0,0,0"
                           HorizontalAlignment="Left"
                           FontSize="12"
                           Text="{Binding NoteDisplay}"
                           TextAlignment="Left"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DisplayTemplate">
            <TextBlock FontSize="12"
                       Text="{Binding Display}"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </DataTemplate>
    </ui:ContentDialog.Resources>

    <ui:ContentDialog.Title>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <ui:SymbolIcon Symbol="Edit32" Margin="0,0,8,0" FontSize="16"/>
            <TextBlock Text="Edit Song" />
        </StackPanel>
    </ui:ContentDialog.Title>

    <StackPanel x:Name="DialogContentPanel"
                Background="Transparent"
                Margin="12,0,12,0">
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Title"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ui:TextBox x:Name="TitleBox" ClearButtonEnabled="False"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Album"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ui:TextBox x:Name="AlbumBox"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Artist"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <ui:TextBox x:Name="ArtistBox"
                    Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Base Key Offset"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <button:StandardDropdown x:Name="BaseKeyComboBox"
                              Width="160"
                              HorizontalAlignment="Left"
                              ItemTemplate="{StaticResource OffsetNoteTemplate}"
                              Cursor="Hand"
                              SelectionChanged="OnBaseKeyComboBoxSelectionChanged"/>
                    <controls:Button x:Name="RescanBaseKeyButton"
                                     Margin="6,0,0,0"
                                     Width="32"
                                     Height="32"
                                     Variant="Ghost"
                                     Icon="ScanDash12"
                                     ToolTip="Auto-scan base key offset from MIDI"
                                     Click="RescanBaseKeyButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Key Offset"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <button:StandardDropdown x:Name="KeyComboBox"
                          Width="160"
                          HorizontalAlignment="Left"
                          ItemTemplate="{StaticResource OffsetNoteTemplate}"
                          Cursor="Hand"
                          SelectionChanged="OnKeyComboBoxSelectionChanged"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Transpose"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <button:StandardDropdown x:Name="TransposeComboBox"
                          Width="160"
                          HorizontalAlignment="Left"
                          ItemTemplate="{StaticResource DisplayTemplate}"
                          Cursor="Hand"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="BPM"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ui:TextBox x:Name="BpmBox"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Speed"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <button:StandardDropdown x:Name="SpeedComboBox"
                          Width="160"
                          HorizontalAlignment="Left"
                          ItemTemplate="{StaticResource DisplayTemplate}"
                          Cursor="Hand"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Merge Notes"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <ui:ToggleSwitch x:Name="MergeNotesToggle"
                                     Checked="MergeNotesToggle_Checked"
                                     Unchecked="MergeNotesToggle_Unchecked"/>
                    <TextBlock Text="Tolerance (ms):"
                               Margin="12,0,8,0"
                               VerticalAlignment="Center"/>
                    <ui:TextBox x:Name="MergeMillisecondsBox"
                                Width="80"
                                IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <TextBlock Text="Hold Notes"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4"/>
        <ui:ToggleSwitch x:Name="HoldNotesToggle"/>


        <Separator Margin="0,10,0,10"/>

        <controls:Hyperlink x:Name="PathHyperlink"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,0"
                            Click="PathHyperlink_Click">
            <TextBlock x:Name="PathTextBlock"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       ToolTipService.InitialShowDelay="400"
                       ToolTipService.Placement="Top"/>
        </controls:Hyperlink>
        
        <TextBlock x:Name="DateText"
                   Margin="0,0,0,0"
                   FontSize="11"
                   Opacity="0.7"
                   Foreground="#FFD2D2D2"/>
    </StackPanel>
</ui:ContentDialog>
