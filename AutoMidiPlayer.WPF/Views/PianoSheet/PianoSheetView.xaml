<UserControl
    x:Class="AutoMidiPlayer.WPF.Views.PianoSheetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:AutoMidiPlayer.WPF.ViewModels"
    xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
    d:DataContext="{d:DesignInstance Type=viewModels:PianoSheetViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SimpleStackPanel Grid.Row="0">
            <WrapPanel>
                <GroupBox Header="Delimiter" VerticalAlignment="Top" Margin="0,0,12,12">
                    <TextBox Text="{Binding Delimiter, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="80"/>
                </GroupBox>

                <GroupBox Header="Layout" VerticalAlignment="Top" Margin="0,0,12,12">
                    <ComboBox
                        ItemsSource="{Binding InstrumentPage.AvailableLayouts}"
                        SelectedItem="{Binding SelectedLayout}"
                        DisplayMemberPath="Value"
                        MinWidth="150"/>
                </GroupBox>

                <GroupBox Header="Split Size" VerticalAlignment="Top" Margin="0,0,12,12">
                    <controls:SimpleStackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel>
                            <TextBlock Text="Bars" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding Bars, UpdateSourceTrigger=PropertyChanged}"
                                          Minimum="0"
                                          MinWidth="80"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Beats" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding Beats, UpdateSourceTrigger=PropertyChanged}"
                                          Minimum="0"
                                          MinWidth="80"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Shorten every" Margin="0,0,0,4"/>
                            <ui:NumberBox Value="{Binding Shorten, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="This will divide the delimiter by this number"
                                          Minimum="1"
                                          MinWidth="80"/>
                        </StackPanel>
                    </controls:SimpleStackPanel>
                </GroupBox>
            </WrapPanel>
        </controls:SimpleStackPanel>

        <controls:CopyableTextBox Grid.Row="1"
                                  Margin="0,8,0,10"
                                  Text="{Binding Result, Mode=OneWay}"
                                  TextWrapping="NoWrap"
                                  HorizontalScrollBarVisibility="Visible"
                                  VerticalScrollBarVisibility="Auto"
                                  CopyToolTip="Copy sheet output"/>
    </Grid>
</UserControl>
