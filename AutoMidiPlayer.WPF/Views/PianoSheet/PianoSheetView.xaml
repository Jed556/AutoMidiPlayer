<UserControl
    x:Class="AutoMidiPlayer.WPF.Views.PianoSheetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:AutoMidiPlayer.WPF.ViewModels"
    xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
    xmlns:button="clr-namespace:AutoMidiPlayer.WPF.Controls.SelectorPopupButton.Button"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:noSong="clr-namespace:AutoMidiPlayer.WPF.Controls.NoSongPlaceholder"
    d:DataContext="{d:DesignInstance Type=viewModels:PianoSheetViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SimpleStackPanel Grid.Row="0">
            <WrapPanel>
                <GroupBox Header="Delimiter"
                        VerticalAlignment="Top"
                        Margin="0,0,12,12">
                    <StackPanel>
                        <TextBox Text="{Binding Delimiter, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="50"
                                 Width="50"
                                 HorizontalAlignment="Left"/>
                        
                        <controls:SimpleStackPanel Orientation="Horizontal"
                                                   Spacing="4"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding IsDelimiterWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="Warning20" 
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           FontSize="14"/>
                            <TextBlock Text="{Binding DelimiterWarningText}"
                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </controls:SimpleStackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Layout"
                        VerticalAlignment="Top"
                        Margin="0,0,12,12">
                    <button:StandardDropdown
                        ItemsSource="{Binding InstrumentPage.AvailableLayouts}"
                        SelectedItem="{Binding SelectedLayout}"
                        DisplayMemberPath="Value"
                        HorizontalAlignment="Left"
                        MinWidth="150"/>
                </GroupBox>

                <GroupBox Header="Split Size"
                        VerticalAlignment="Top"
                        Margin="0,0,12,12">
                    <controls:SimpleStackPanel Orientation="Horizontal"
                            Spacing="8">
                        <StackPanel>
                            <TextBlock Text="Bars"
                                    Margin="0,0,0,4"/>
                            <controls:Numberbox Value="{Binding Bars, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Beats"
                                    Margin="0,0,0,4"/>
                            <controls:Numberbox Value="{Binding Beats, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="1"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Shorten every"
                                    Margin="0,0,0,4"/>
                            <controls:Numberbox Value="{Binding Shorten, UpdateSourceTrigger=PropertyChanged}"
                                                ToolTip="This will divide the delimiter by this number"
                                                Minimum="1"/>
                        </StackPanel>
                    </controls:SimpleStackPanel>
                </GroupBox>
                
                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <controls:Button Variant="Ghost"
                                     Icon="Info24"
                                     Command="{s:Action ShowLegend}"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Margin="0,0,0,4"
                                     Content="Legend"/>
                    <controls:Button Variant="Ghost"
                                     ColorMode="Danger"
                                     Icon="ArrowClockwise24"
                                     Command="{s:Action ResetDefaults}"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Content="Reset defaults"/>
                </StackPanel>
            </WrapPanel>
        </controls:SimpleStackPanel>

        <controls:CopyableTextBox Grid.Row="1"
                                      Margin="0,8,0,10"
                                      Text="{Binding Result, Mode=OneWay}"
                                      Delimiter="{Binding Delimiter, Mode=OneWay}"
                                      HorizontalScrollBarVisibility="Visible"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasSongOpen, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                      CopyToolTip="Copy sheet output"/>
                                      
        <ContentControl Grid.Row="1" Visibility="{Binding HasSongOpen, Converter={x:Static s:BoolToVisibilityConverter.InverseInstance}}">
            <noSong:NoSongPlaceholder DataContext="{Binding Placeholder}" />
        </ContentControl>
    </Grid>
</UserControl>
