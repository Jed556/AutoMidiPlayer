<UserControl
    x:Class="AutoMidiPlayer.WPF.Views.OnlineMidiView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:viewModels="clr-namespace:AutoMidiPlayer.WPF.ViewModels"
    xmlns:midishow="clr-namespace:AutoMidiPlayer.WPF.Services.MidiShow"
    xmlns:converters="clr-namespace:AutoMidiPlayer.WPF.Converters"
    d:DataContext="{d:DesignInstance Type=viewModels:OnlineMidiViewModel}">

    <UserControl.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:UrlToCachedImageConverter x:Key="UrlToCachedImageConverter"/>

        <!-- Icons inside buttons don't inherit the button foreground in this app, so they
             default to the accent (green). Force a neutral foreground; icons that need a
             colour (gold star, green check) set Foreground explicitly and override this. -->
        <Style TargetType="ui:SymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style x:Key="StatChip" TargetType="Border">
            <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ui:ThemeResource ControlElevationBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <!-- Result card with a subtle hover highlight -->
        <Style x:Key="ResultCard" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ Toolbar: row 0 = search + account, row 1 = filters ============ -->
        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox x:Name="SearchBox"
                        Grid.Row="0"
                        Grid.Column="0"
                        PlaceholderText="Search MidiShow by track, artist, keyword..."
                        Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                        Icon="Search12"
                        ClearButtonEnabled="False"
                        VerticalAlignment="Center"
                        KeyDown="SearchBox_KeyDown"/>

            <ui:Button Grid.Row="0"
                       Grid.Column="1"
                       Appearance="Primary"
                       Margin="8,0,0,0"
                       Padding="16,7"
                       VerticalAlignment="Center"
                       Command="{s:Action Search}"
                       Content="Search"/>

            <!-- Filter row -->
            <StackPanel Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        Margin="0,10,0,0">

            <ui:DropDownButton Appearance="Secondary"
                               Padding="12,7"
                               VerticalAlignment="Center"
                               ToolTip="Filter by category">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="TagMultiple24" FontSize="16" Margin="0,0,7,0"/>
                    <TextBlock VerticalAlignment="Center" Text="{Binding SelectedCategoryName, FallbackValue='All categories'}"/>
                </StackPanel>
                <ui:DropDownButton.Flyout>
                    <ContextMenu>
                        <MenuItem Header="All categories" Tag="" Click="Category_Click"/>
                        <Separator/>
                        <MenuItem Header="Pop Music" Tag="pop-music" Click="Category_Click"/>
                        <MenuItem Header="Anime / Game music" Tag="game-music" Click="Category_Click"/>
                        <MenuItem Header="Film Score" Tag="movie_tv_soundtrack" Click="Category_Click"/>
                        <MenuItem Header="Classical Music" Tag="classical-music" Click="Category_Click"/>
                        <MenuItem Header="Electronic Music" Tag="electronic-music" Click="Category_Click"/>
                        <MenuItem Header="Rock" Tag="rock-and-roll" Click="Category_Click"/>
                        <MenuItem Header="Jazz" Tag="jazz-and-blues" Click="Category_Click"/>
                        <MenuItem Header="Country Music" Tag="country-music" Click="Category_Click"/>
                        <MenuItem Header="Rhythm &amp; Blues" Tag="rhythm-and-blues" Click="Category_Click"/>
                        <MenuItem Header="Hip / Rap Music" Tag="hip-hop-and-rap" Click="Category_Click"/>
                        <MenuItem Header="Latin" Tag="latin-music" Click="Category_Click"/>
                        <MenuItem Header="Folk Music" Tag="national-music" Click="Category_Click"/>
                        <MenuItem Header="Ballad" Tag="folk-music" Click="Category_Click"/>
                        <MenuItem Header="Easy Listening" Tag="easy-listening-music" Click="Category_Click"/>
                        <MenuItem Header="Children's Music" Tag="childrens-music" Click="Category_Click"/>
                        <MenuItem Header="Religious Music" Tag="religious-music" Click="Category_Click"/>
                        <MenuItem Header="Other Music" Tag="other-music" Click="Category_Click"/>
                    </ContextMenu>
                </ui:DropDownButton.Flyout>
            </ui:DropDownButton>

            <ui:DropDownButton Appearance="Secondary"
                               Margin="8,0,0,0"
                               Padding="12,7"
                               VerticalAlignment="Center"
                               ToolTip="Sort results">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowSort24" FontSize="16" Margin="0,0,7,0"/>
                    <TextBlock VerticalAlignment="Center" Text="{Binding SortLabel, FallbackValue=Newest}"/>
                </StackPanel>
                <ui:DropDownButton.Flyout>
                    <ContextMenu>
                        <MenuItem Header="Newest" Tag="" Click="Sort_Click">
                            <MenuItem.Icon><ui:SymbolIcon Symbol="CalendarArrowDown24"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Oldest" Tag="time_asc" Click="Sort_Click">
                            <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowSortUpLines24"/></MenuItem.Icon>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Most popular" Tag="popularity" Click="Sort_Click">
                            <MenuItem.Icon><ui:SymbolIcon Symbol="Fire24"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="Highest rated" Tag="marks" Click="Sort_Click">
                            <MenuItem.Icon><ui:SymbolIcon Symbol="StarEmphasis24"/></MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ui:DropDownButton.Flyout>
            </ui:DropDownButton>

            <ui:Button Appearance="Secondary"
                       Margin="8,0,0,0"
                       Padding="10,7"
                       VerticalAlignment="Center"
                       ToolTip="Refresh list"
                       Command="{s:Action Reload}">
                <ui:SymbolIcon Symbol="ArrowSync24"
                               FontSize="16"/>
            </ui:Button>
            </StackPanel>

            <!-- Account: a single toolbar button that opens a sign-in / profile popup,
                 keeping the page body free for search + results. -->
            <Grid Grid.Row="0" Grid.Column="2" x:Name="AccountAnchor" Margin="8,0,0,0">
                <ui:Button Appearance="Primary"
                           Padding="13,7"
                           VerticalAlignment="Center"
                           ToolTip="Sign in to MidiShow"
                           Command="{s:Action ToggleAccountFlyout}"
                           Visibility="{Binding IsSignedIn, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="PersonCircle24" FontSize="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Sign in"/>
                    </StackPanel>
                </ui:Button>

                <ui:Button Appearance="Secondary"
                           Padding="11,7"
                           VerticalAlignment="Center"
                           ToolTip="{Binding SignedInUser, StringFormat='Signed in as {0}'}"
                           Command="{s:Action ToggleAccountFlyout}"
                           Visibility="{Binding IsSignedIn, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="16" Foreground="#2EA043" Margin="0,0,6,0"/>
                        <TextBlock Text="Account" Margin="0,0,6,0"/>
                        <ui:SymbolIcon Symbol="ChevronDown12" FontSize="11" Opacity="0.7"/>
                    </StackPanel>
                </ui:Button>

                <Popup PlacementTarget="{Binding ElementName=AccountAnchor}"
                       Placement="Bottom"
                       HorizontalOffset="-256"
                       VerticalOffset="6"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       StaysOpen="False"
                       IsOpen="{Binding IsAccountFlyoutOpen, Mode=TwoWay}">
                    <Border Width="340"
                            Padding="18"
                            CornerRadius="10"
                            Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                            BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.35" Color="Black"/>
                        </Border.Effect>

                        <Grid>
                        <!-- Signed OUT: sign-in form + how-to-register -->
                        <StackPanel Visibility="{Binding IsSignedIn, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <ui:SymbolIcon Symbol="PersonLock24" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Sign in to MidiShow" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ui:TextBox Margin="0,0,0,8"
                                        PlaceholderText="Email or username"
                                        ClearButtonEnabled="False"
                                        Text="{Binding LoginUsername, UpdateSourceTrigger=PropertyChanged}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- masked -->
                                <ui:PasswordBox x:Name="PasswordBox"
                                                Grid.Column="0"
                                                PlaceholderText="Password"
                                                ClearButtonEnabled="False"
                                                RevealButtonEnabled="False"
                                                Password="{Binding LoginPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                KeyDown="PasswordBox_KeyDown"
                                                Visibility="{Binding IsPasswordRevealed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <!-- revealed (plain text) -->
                                <ui:TextBox Grid.Column="0"
                                            PlaceholderText="Password"
                                            ClearButtonEnabled="False"
                                            Text="{Binding LoginPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            KeyDown="PasswordBox_KeyDown"
                                            Visibility="{Binding IsPasswordRevealed, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>

                                <ui:Button Grid.Column="1"
                                           Margin="6,0,0,0"
                                           Padding="9,0"
                                           VerticalAlignment="Stretch"
                                           ToolTip="Show / hide password"
                                           Command="{s:Action ToggleReveal}">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="EyeLines24" FontSize="16" Opacity="0.75"
                                                       Visibility="{Binding IsPasswordRevealed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        <ui:SymbolIcon Symbol="EyeOff24" FontSize="16" Opacity="0.75"
                                                       Visibility="{Binding IsPasswordRevealed, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                                    </Grid>
                                </ui:Button>
                            </Grid>
                            <CheckBox Content="Remember me on this device"
                                      IsChecked="{Binding RememberMe}"
                                      Margin="0,2,0,12"/>
                            <ui:Button Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Padding="0,9"
                                       IsEnabled="{Binding IsNotBusy}"
                                       Command="{s:Action SignIn}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="ArrowEnter20" FontSize="15" Margin="0,0,6,0"/>
                                    <TextBlock Text="Sign in"/>
                                </StackPanel>
                            </ui:Button>

                            <Expander Margin="0,12,0,0"
                                      Header="How to create a MidiShow account">
                                <StackPanel Margin="2,10,2,2">
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="1.  Open the registration page below (or go to midishow.com)."/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="2.  Enter your email, a password (6+ characters) and the captcha. Accept the terms. (Google / Facebook sign-up also works.)"/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="3.  Confirm the verification email from MidiShow."/>
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="4.  Come back and sign in with the same email and password."/>
                                    <ui:Button Appearance="Secondary" HorizontalAlignment="Left" Padding="12,6" Command="{s:Action OpenRegisterPage}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Globe28" FontSize="15" Margin="0,0,6,0"/>
                                            <TextBlock Text="Open registration page"/>
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <!-- Signed IN: profile + sign out -->
                        <StackPanel Visibility="{Binding IsSignedIn, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20" Foreground="#2EA043" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Signed in" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SignedInUser, Mode=OneWay}" Opacity="0.7" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Tracks you add go straight into your Songs library."
                                       Opacity="0.55" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,14"/>
                            <ui:Button Appearance="Secondary" HorizontalAlignment="Stretch"
                                       Padding="0,9"
                                       Command="{s:Action SignOut}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="SignOut24" FontSize="15" Margin="0,0,6,0"/>
                                    <TextBlock Text="Sign out"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                        </Grid>
                    </Border>
                </Popup>
            </Grid>
        </Grid>

        <!-- ============ Preview mini-player (separate player; not Listen Mode) ============ -->
        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="12,9"
                CornerRadius="10"
                Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                BorderThickness="1"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Style>
                <!-- Smooth slide + fade + grow on appear, and fade + shrink on close. -->
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPreviewActive}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Visible}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.22"/>
                                        <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                         From="0" To="90" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         From="-10" To="0" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.16"/>
                                        <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                         To="0" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-10" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.16" Duration="0:0:0">
                                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{x:Static Visibility.Collapsed}"/>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Play / pause -->
                <ui:Button Grid.Column="0"
                           Appearance="Secondary"
                           Padding="8,6"
                           VerticalAlignment="Center"
                           ToolTip="Play / pause preview"
                           Command="{s:Action PreviewPlayPause}">
                    <Grid>
                        <ui:SymbolIcon Symbol="PlayCircle24" FontSize="18"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       Visibility="{Binding IsPreviewPlaying, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <ui:SymbolIcon Symbol="PauseCircle24" FontSize="18"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       Visibility="{Binding IsPreviewPlaying, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                    </Grid>
                </ui:Button>

                <!-- Stop -->
                <ui:Button Grid.Column="1"
                           Appearance="Secondary"
                           Padding="8,6"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           ToolTip="Stop preview"
                           Command="{s:Action StopPreview}">
                    <ui:SymbolIcon Symbol="RecordStop24" FontSize="16"/>
                </ui:Button>

                <!-- Title + seekbar -->
                <StackPanel Grid.Column="2" Margin="14,0,12,0" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,0,1">
                        <Run Text="Previewing" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <Run Text="{Binding PreviewTitle, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <Slider x:Name="PreviewSeek"
                            Minimum="0"
                            Maximum="{Binding PreviewDurationSeconds}"
                            Value="{Binding PreviewPositionSeconds, Mode=TwoWay}"
                            IsMoveToPointEnabled="True"
                            VerticalAlignment="Center"
                            Thumb.DragStarted="PreviewSeek_DragStarted"
                            Thumb.DragCompleted="PreviewSeek_DragCompleted"
                            PreviewMouseLeftButtonUp="PreviewSeek_MouseUp"/>
                </StackPanel>

                <!-- Time -->
                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                           Opacity="0.7" FontSize="12" MinWidth="78" TextAlignment="Right">
                    <Run Text="{Binding PreviewPositionText, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding PreviewDurationText, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ============ Results ============ -->
        <Grid Grid.Row="2">
            <!-- Virtualized so only the visible cards are realized; each card is a fairly heavy
                 visual tree, and paging rebuilds the whole list. -->
            <ListBox ItemsSource="{Binding Results}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,0,8,0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1"
                     VirtualizingPanel.CacheLengthUnit="Page">
                <ListBox.ItemContainerStyle>
                    <!-- Strip all ListBoxItem chrome (selection/hover highlight, padding); the card
                         draws its own hover state and the items aren't meant to be "selected". -->
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type midishow:MidiShowItem}">
                            <Border Style="{StaticResource ResultCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Circular thumbnail -->
                                    <Grid Grid.Column="0"
                                          Width="50" Height="50"
                                          VerticalAlignment="Top"
                                          Margin="0,0,14,0">
                                        <Ellipse Fill="{ui:ThemeResource ControlFillColorSecondaryBrush}"/>
                                        <Ellipse>
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding ThumbnailUrl, Converter={StaticResource UrlToCachedImageConverter}}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <ui:SymbolIcon Symbol="MusicNote224" FontSize="18" Opacity="0.5"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding HasThumbnail, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                    </Grid>

                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="15"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- meta row -->
                                        <WrapPanel Margin="0,5,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <ui:SymbolIcon Symbol="PersonCircle24" FontSize="12" Opacity="0.55" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Uploader, FallbackValue=Unknown}" Opacity="0.7" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center"
                                                        Visibility="{Binding HasRating, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                                <ui:SymbolIcon Symbol="StarEmphasis24" FontSize="12" Foreground="#E5A800" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding RatingDisplay}" Opacity="0.7" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center"
                                                        Visibility="{Binding HasDownloads, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                                <ui:SymbolIcon Symbol="ArrowDownload16" FontSize="12" Opacity="0.55" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Downloads}" Opacity="0.7" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center"
                                                        Visibility="{Binding HasDuration, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                                <ui:SymbolIcon Symbol="Clock12" FontSize="12" Opacity="0.55" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Duration}" Opacity="0.7" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                        Visibility="{Binding HasTrackCount, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                                <ui:SymbolIcon Symbol="Layer24" FontSize="12" Opacity="0.55" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding TrackCount}" Opacity="0.7" FontSize="12"/>
                                            </StackPanel>
                                        </WrapPanel>

                                        <!-- description -->
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,6,0,0" Opacity="0.6" FontSize="12"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasDescription, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>

                                        <!-- category + tags -->
                                        <WrapPanel Margin="0,8,0,0">
                                            <Border Padding="9,2" CornerRadius="9" Margin="0,0,8,0" VerticalAlignment="Center"
                                                    Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                    Visibility="{Binding HasCategory, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                                <TextBlock Text="{Binding Category}" FontSize="10.5" Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding Tags}" Opacity="0.5" FontSize="11.5" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasTags, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Right: standard badge (top) + actions (vertically centred) -->
                                    <Grid Grid.Column="2" Margin="14,0,0,0">
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                Padding="6,1" CornerRadius="4"
                                                Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                                Visibility="{Binding HasStandard, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <TextBlock Text="{Binding Standard}" FontSize="10" Opacity="0.7"/>
                                        </Border>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <ui:Button Appearance="Secondary" Padding="10,8" Margin="0,0,6,0"
                                                       ToolTip="View details (description, BPM, tracks, notes…)"
                                                       Click="Details_Click">
                                                <ui:SymbolIcon Symbol="DocumentText24" FontSize="17"/>
                                            </ui:Button>
                                            <ui:Button Appearance="Secondary" Padding="10,8" Margin="0,0,6,0"
                                                       ToolTip="Preview — play without adding to Songs"
                                                       Click="Preview_Click">
                                                <ui:SymbolIcon Symbol="PlayCircle24" FontSize="17"/>
                                            </ui:Button>
                                            <ui:Button Appearance="Primary" Padding="11,8"
                                                       ToolTip="Download to your Songs library"
                                                       Click="AddToSongs_Click">
                                                <ui:SymbolIcon Symbol="ArrowDownload16" FontSize="18"/>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            <!-- Empty / status state -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{Binding ShowEmptyState, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                <ui:SymbolIcon Symbol="MusicNote224"
                               FontSize="40"
                               Opacity="0.4"
                               HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage, FallbackValue='No MIDI files to show'}"
                           Margin="0,10,0,0"
                           Opacity="0.7"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Busy overlay -->
            <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                    Opacity="0.5"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsBusy, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
            <ui:ProgressRing IsIndeterminate="True"
                             Width="44"
                             Height="44"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>

            <!-- ============ Detail overlay ============ -->
            <Border Background="{ui:ThemeResource ApplicationBackgroundBrush}"
                    Visibility="{Binding IsDetailOpen, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ui:Button Grid.Row="0"
                               Appearance="Secondary"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,12"
                               Padding="10,6"
                               Command="{s:Action CloseDetails}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="15" Margin="0,0,6,0"/>
                            <TextBlock Text="Back to results"/>
                        </StackPanel>
                    </ui:Button>

                    <ui:ProgressRing Grid.Row="1"
                                     IsIndeterminate="True"
                                     Width="44" Height="44"
                                     VerticalAlignment="Center" HorizontalAlignment="Center"
                                     Visibility="{Binding IsDetailLoading, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0,0,10,0"
                                  Visibility="{Binding HasDetails, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"
                                  DataContext="{Binding SelectedDetails}">
                        <StackPanel>
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Grid Width="64" Height="64" Margin="0,0,16,0" VerticalAlignment="Top">
                                    <Ellipse Fill="{ui:ThemeResource ControlFillColorSecondaryBrush}"/>
                                    <Ellipse>
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding ThumbnailUrl, Converter={StaticResource UrlToCachedImageConverter}}" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                                <StackPanel VerticalAlignment="Center" MaxWidth="660">
                                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <ui:SymbolIcon Symbol="PersonCircle24" FontSize="13" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Uploader, FallbackValue=Unknown}" Opacity="0.75" VerticalAlignment="Center"/>
                                        <Border Margin="10,0,0,0" Padding="6,1" CornerRadius="4" VerticalAlignment="Center"
                                                Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                                Visibility="{Binding HasStandard, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <TextBlock Text="{Binding Standard}" FontSize="10" Opacity="0.8"/>
                                        </Border>
                                    </StackPanel>
                                    <WrapPanel Margin="0,8,0,0">
                                        <Border Padding="10,2" CornerRadius="9" Margin="0,0,8,0" VerticalAlignment="Center"
                                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                Visibility="{Binding HasCategory, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding Tags}" Opacity="0.55" FontSize="12" VerticalAlignment="Center"
                                                   Visibility="{Binding HasTags, Converter={x:Static s:BoolToVisibilityConverter.Instance}}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Stat chips -->
                            <WrapPanel Margin="0,0,0,16">
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasDuration, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Clock12" FontSize="13" Opacity="0.7" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Duration}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="Duration" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasBpm, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Timer24" FontSize="13" Opacity="0.7" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Bpm}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="BPM" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasTrackCount, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Layer24" FontSize="13" Opacity="0.7" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding TrackCount}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="Tracks" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasNoteCount, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="MusicNote124" FontSize="13" Opacity="0.7" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding NoteCount}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="Notes" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasFileSize, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="DocumentText24" FontSize="13" Opacity="0.7" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding FileSize}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="Size" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasRating, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="StarEmphasis24" FontSize="13" Foreground="#E5A800" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Rating}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="Rating" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource StatChip}" Visibility="{Binding HasDownloads, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowDownload16" FontSize="13" Opacity="0.7" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Downloads}" FontWeight="SemiBold" Margin="0,0,5,0"/>
                                        <TextBlock Text="Downloads" Opacity="0.55"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <!-- Instruments -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16"
                                        Visibility="{Binding HasInstruments, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                <ui:SymbolIcon Symbol="Guitar28" FontSize="15" Opacity="0.7" VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <TextBlock Text="{Binding Instruments}" Opacity="0.85" TextWrapping="Wrap" MaxWidth="700"/>
                            </StackPanel>

                            <!-- Introduction -->
                            <StackPanel Visibility="{Binding HasIntroduction, Converter={x:Static s:BoolToVisibilityConverter.Instance}}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ui:SymbolIcon Symbol="TextDescription24" FontSize="15" Opacity="0.7" Margin="0,0,7,0"/>
                                    <TextBlock Text="Introduction" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Border Background="{ui:ThemeResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="14">
                                    <TextBlock Text="{Binding Introduction}"
                                               Opacity="0.85"
                                               TextWrapping="Wrap"
                                               TextAlignment="Left"
                                               HorizontalAlignment="Left"
                                               LineHeight="21"/>
                                </Border>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,8">
                                <ui:Button Appearance="Secondary" Padding="14,8" Margin="0,0,8,0" Command="{s:Action PreviewSelectedAsync}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="PlayCircle24" FontSize="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Preview"/>
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button Appearance="Primary" Padding="14,8" Margin="0,0,8,0" Command="{s:Action AddSelectedToSongs}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowDownload16" FontSize="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Download to Songs"/>
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button Appearance="Secondary" Padding="14,8" Command="{s:Action OpenDetailPage}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Globe28" FontSize="15" Margin="0,0,6,0"/>
                                        <TextBlock Text="Open on MidiShow"/>
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ============ Footer: status + pagination ============ -->
        <Grid Grid.Row="3"
              Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding StatusMessage}"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <ui:Button Appearance="Secondary"
                           Padding="10,6"
                           Margin="0,0,6,0"
                           ToolTip="Previous page"
                           IsEnabled="{Binding CanGoToPreviousPage}"
                           Command="{s:Action PreviousPage}">
                    <ui:SymbolIcon Symbol="ChevronLeft24"
                                   FontSize="15"/>
                </ui:Button>
                <Border Padding="12,0"
                        MinWidth="40"
                        VerticalAlignment="Stretch"
                        CornerRadius="6"
                        Background="{ui:ThemeResource ControlFillColorSecondaryBrush}">
                    <TextBlock VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="{Binding CurrentPage}"/>
                </Border>
                <ui:Button Appearance="Secondary"
                           Padding="10,6"
                           Margin="6,0,0,0"
                           ToolTip="Next page"
                           IsEnabled="{Binding CanGoToNextPage}"
                           Command="{s:Action NextPage}">
                    <ui:SymbolIcon Symbol="ChevronRight24"
                                   FontSize="15"/>
                </ui:Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
