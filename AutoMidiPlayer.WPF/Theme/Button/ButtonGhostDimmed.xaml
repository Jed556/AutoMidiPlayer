<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:AutoMidiPlayer.WPF.Controls"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Color x:Key="ButtonDangerNormalColor">#FFC42B1C</Color>
    <Color x:Key="ButtonDangerWarningColor">#FFB900</Color>

    <Style x:Key="ButtonGhostDimmed" TargetType="{x:Type controls:Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Button}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <StackPanel x:Name="ContentPanel"
                                    Orientation="Horizontal"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                            
                            <ui:SymbolIcon x:Name="LeftIcon" 
                                           Symbol="{TemplateBinding Icon}" 
                                           Filled="{TemplateBinding IconFilled}"
                                           FontSize="{TemplateBinding IconFontSize}"
                                           Visibility="Collapsed" />
                                           
                            <ContentPresenter x:Name="ContentPresenter" 
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                                              
                            <ui:SymbolIcon x:Name="RightIcon" 
                                           Symbol="{TemplateBinding Icon}" 
                                           Filled="{TemplateBinding IconFilled}"
                                           FontSize="{TemplateBinding IconFontSize}"
                                           Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Icon Placement -->
                        <!-- Icon Placement when HasContent is True -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IconPlacement" Value="Left" />
                                <Condition Property="HasContent" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LeftIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="LeftIcon" Property="Margin" Value="0,0,6,0" />
                            <Setter TargetName="RightIcon" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IconPlacement" Value="Right" />
                                <Condition Property="HasContent" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LeftIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RightIcon" Property="Margin" Value="6,0,0,0" />
                        </MultiTrigger>

                        <!-- Icon Placement when HasContent is False -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IconPlacement" Value="Left" />
                                <Condition Property="HasContent" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LeftIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="LeftIcon" Property="Margin" Value="0" />
                            <Setter TargetName="RightIcon" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IconPlacement" Value="Right" />
                                <Condition Property="HasContent" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LeftIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RightIcon" Property="Margin" Value="0" />
                        </MultiTrigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="LeftIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RightIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- ColorModes -->
                        <Trigger Property="ColorMode" Value="Default">
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.25" />
                        </Trigger>
                        <Trigger Property="ColorMode" Value="Accent">
                            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <Trigger Property="ColorMode" Value="Warning">
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ButtonDangerWarningColor}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <Trigger Property="ColorMode" Value="Danger">
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource ButtonDangerNormalColor}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.8" />
                        </Trigger>

                        <!-- Animations -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsActive" Value="False" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPanel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.75"
                                                         Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <DoubleAnimation Storyboard.TargetName="ContentPanel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsActive" Value="True" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPanel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard FillBehavior="Stop">
                                        <DoubleAnimation Storyboard.TargetName="ContentPanel"
                                                         Storyboard.TargetProperty="Opacity"
                                                         Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.5" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.2" />
                            <Setter TargetName="RootBorder" Property="Opacity" Value="0.55"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                        </Trigger>

                        <!-- Active State for Default ColorMode -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsActive" Value="True" />
                                <Condition Property="ColorMode" Value="Default" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <Setter TargetName="ContentPanel" Property="Opacity" Value="0.8" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
