<ui:MessageBox x:Class="AutoMidiPlayer.WPF.MessageBox.CrashMessageBox"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
               Title=""
               ShowTitle="False"
               CloseButtonText="OK"
               CloseButtonAppearance="Secondary">

    <StackPanel>
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,8">
            <ui:SymbolIcon Symbol="ErrorCircle12"
                           FontSize="24"
                           Margin="0,0,8,0"
                           Filled="True"/>

            <TextBlock Text="AutoMidiPlayer Error"
                       FontWeight="Bold"
                       FontSize="24"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Margin="0,0,0,8"
                   TextWrapping="Wrap">
            <Run Text="An error occurred. Log saved to:"/>
            <LineBreak/>
            <Hyperlink x:Name="LogPathHyperlink"
                       Click="OnLogPathClick">
                <Run x:Name="LogPathRun"/>
            </Hyperlink>
        </TextBlock>

        <Grid x:Name="ErrorGrid"
              MouseEnter="OnErrorGridMouseEnter"
              MouseLeave="OnErrorGridMouseLeave">

            <TextBox x:Name="ErrorTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     MaxHeight="200"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent"
                     BorderThickness="1"
                     Padding="8,6,36,6"
                     FontSize="14"/>

            <Button x:Name="CopyButton"
                    ToolTip="Copy error message"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4"
                    Cursor="Hand"
                    Opacity="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,4,4,0"
                    Click="OnCopyClick"
                    MouseEnter="OnCopyButtonMouseEnter">
                <ui:SymbolIcon Symbol="Copy16"
                               FontSize="18"/>
            </Button>
        </Grid>
    </StackPanel>
</ui:MessageBox>
